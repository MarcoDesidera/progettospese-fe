{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/static/media/*.{png,jpg,gif}", "/static/css/*"]
  },
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  },
  "routes": [
    {
      "route": "*",
      "condition": {
        "hostName": "progettospese.it"
      },
      "redirect": "https://www.progettospese.it",
      "statusCode": 301
    }
  ]
}
